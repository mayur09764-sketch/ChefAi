let activePill='All';
function setPill(el){
  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('on'));
  el.classList.add('on');
  activePill=el.textContent.trim();
}

// ═══ GENERATE RECIPE ═══
async function generateRecipe(){
  const ing=document.getElementById('aiIngredients').value.trim();
  if(!ing){document.getElementById('aiIngredients').focus();return;}
  const cuisine=document.getElementById('aiCuisine').value.replace(/[🇮🇳🇮🇹🇨🇳🇲🇽🌍]/gu,'').trim();
  const servings=document.getElementById('aiServings').value;
  const difficulty=document.getElementById('aiDifficulty').value;
  const diet=activePill;

  const btn=document.getElementById('genBtn');
  btn.disabled=true;
  document.getElementById('genBtnText').textContent='⏳ Generating...';
  document.getElementById('aiResult').classList.remove('show');
  document.getElementById('aiLoading').classList.add('show');

  const loadingMsgs=["Analysing your ingredients...","Finding the perfect dish...","Crafting step-by-step guide...","Adding chef's secrets..."];
  let li=0;
  const lt=setInterval(()=>{
    document.getElementById('aiLoadingStep').textContent=loadingMsgs[li%loadingMsgs.length];
    li++;
  },1200);

  const systemPrompt=`You are a professional chef AI. Always respond in valid JSON only. No markdown, no explanation outside JSON.`;
  const userPrompt=`Create a ${diet} ${cuisine} recipe using these ingredients: ${ing}. Servings: ${servings}. Difficulty: ${difficulty}.
Respond ONLY with this exact JSON structure:
{
  "name": "Recipe Name",
  "time": "X mins",
  "calories": "XXX kcal",
  "servings": "${servings}",
  "difficulty": "${difficulty}",
  "ingredients": [
    {"name": "Ingredient name", "qty": "amount"}
  ],
  "steps": [
    "Step 1 description",
    "Step 2 description"
  ],
  "tip": "One professional chef tip"
}`;

  try {
    const raw=await callGemini(systemPrompt, userPrompt, 4000);
    clearInterval(lt);
    const clean=raw.replace(/```json|```/g,'').trim();
    const recipe=JSON.parse(clean);
    renderAIRecipe(recipe);
  } catch(e){
    clearInterval(lt);
    document.getElementById('aiLoadingStep').textContent='❌ Error: '+e.message+'. Please try again.';
    setTimeout(()=>{
      document.getElementById('aiLoading').classList.remove('show');
      btn.disabled=false;
      document.getElementById('genBtnText').textContent='✦ Generate My Recipe';
    },3000);
    return;
  }

  document.getElementById('aiLoading').classList.remove('show');
  btn.disabled=false;
  document.getElementById('genBtnText').textContent='✦ Generate My Recipe';
}

function renderAIRecipe(r){
  document.getElementById('aiDishName').textContent='🍽️ '+r.name;
  document.getElementById('aiDishMeta').innerHTML=
    `<span>⏱ ${r.time}</span><span>⚡ ${r.calories}</span><span>🍽️ ${r.servings}</span><span>📊 ${r.difficulty}</span>`;
  document.getElementById('aiIngList').innerHTML=
    r.ingredients.map(i=>`<div class="ai-ing-item">${i.name}<span>${i.qty}</span></div>`).join('');
  document.getElementById('aiStepsList').innerHTML=
    r.steps.map((s,i)=>`<li class="ai-step"><div class="ai-step-num">${i+1}</div><div class="ai-step-text">${s}</div></li>`).join('');
  document.getElementById('aiTipBox').innerHTML=`💡 <b>Chef's Tip:</b> ${r.tip}`;
  document.getElementById('aiResult').classList.add('show');
  document.getElementById('aiResult').scrollIntoView({behavior:'smooth',block:'nearest'});
  currentAIRecipe = r; // store for shopping list
}

