  grid.innerHTML=days.map(d=>`
    <div class="plan-day">
      <div class="plan-day-label">${d}</div>
      <div class="plan-meal loading"><div class="plan-meal-type">Breakfast</div><div class="plan-meal-name">Generating...</div></div>
      <div class="plan-meal loading"><div class="plan-meal-type">Lunch</div><div class="plan-meal-name">Generating...</div></div>
      <div class="plan-meal loading"><div class="plan-meal-type">Dinner</div><div class="plan-meal-name">Generating...</div></div>
