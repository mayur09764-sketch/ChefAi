

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ChefAI — Your Smart Kitchen Assistant</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#FAF6F1;--primary:#E85D04;--secondary:#F48C06;--white:#FFFFFF;--text:#1A1A1A;--text2:#555;--veg:#16A34A;--nonveg:#DC2626;--muted:#888;--border:#E8E0D8;}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;}

/* NAV */
nav{background:var(--white);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:200;padding:0 5%;height:64px;display:flex;align-items:center;justify-content:space-between;}
.logo{display:flex;align-items:center;gap:8px;text-decoration:none;}
.logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--primary),var(--secondary));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:17px;}
.logo-name{font-family:'Sora',sans-serif;font-size:20px;font-weight:800;color:var(--primary);}
.nav-links{display:flex;gap:28px;list-style:none;}
.nav-links a{text-decoration:none;color:var(--text2);font-size:14px;font-weight:600;transition:color .2s;cursor:pointer;}
.nav-links a:hover{color:var(--primary);}
.btn-login{background:var(--primary);color:#fff;border:none;padding:9px 22px;border-radius:8px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 3px 12px rgba(232,93,4,.28);}
.btn-login:hover{background:#cf4f00;transform:translateY(-1px);}

/* HERO */
.hero{position:relative;height:82vh;min-height:500px;display:flex;align-items:center;overflow:hidden;}
.hero-img{position:absolute;inset:0;background:linear-gradient(to right,rgba(15,12,10,0.75) 0%,rgba(15,12,10,0.42) 55%,rgba(15,12,10,0.1) 100%),url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1600&q=85') center/cover no-repeat;}
.hero-content{position:relative;z-index:2;padding:0 7%;max-width:580px;}
.hero-content h1{font-family:'Sora',sans-serif;font-size:clamp(2.2rem,4.5vw,3.8rem);font-weight:800;color:#fff;line-height:1.1;margin-bottom:16px;animation:fadeUp .6s ease both;}
.hero-content h1 span{color:var(--secondary);}
.hero-content p{font-size:16px;color:rgba(255,255,255,.82);line-height:1.65;margin-bottom:30px;font-weight:400;max-width:440px;animation:fadeUp .6s .12s ease both;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp .6s .22s ease both;}
.btn-hf{padding:13px 28px;border-radius:8px;border:none;background:var(--primary);color:#fff;font-family:'Nunito',sans-serif;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(232,93,4,.4);transition:all .2s;}
.btn-hf:hover{background:#cf4f00;transform:translateY(-2px);}
.btn-ho{padding:13px 28px;border-radius:8px;border:2px solid rgba(255,255,255,.7);background:rgba(255,255,255,.08);color:#fff;font-family:'Nunito',sans-serif;font-size:15px;font-weight:700;cursor:pointer;backdrop-filter:blur(6px);transition:all .2s;display:flex;align-items:center;gap:6px;}
.btn-ho:hover{background:rgba(255,255,255,.18);border-color:#fff;transform:translateY(-2px);}

/* SECTIONS */
.sec{padding:56px 5%;}
.sec-cream{background:var(--bg);}
.sec-white{background:#fff;}
.sec-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;}
.sec-left{display:flex;align-items:center;gap:12px;}
.sec-bar{width:4px;height:28px;border-radius:4px;flex-shrink:0;}
.bar-g{background:var(--veg);}.bar-r{background:var(--nonveg);}.bar-ai{background:linear-gradient(135deg,var(--primary),var(--secondary));}
.sec-title{font-family:'Sora',sans-serif;font-size:1.45rem;font-weight:700;}
.view-all{font-size:13px;font-weight:700;color:var(--primary);text-decoration:none;transition:opacity .2s;}
.view-all:hover{opacity:.7;}

/* DISH CARDS */
.dish-row{display:flex;gap:18px;overflow-x:auto;padding-bottom:8px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.dish-row::-webkit-scrollbar{height:3px;}
.dish-row::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
.dcard{flex:0 0 270px;background:var(--white);border-radius:14px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.09);transition:transform .25s,box-shadow .25s;cursor:pointer;border:1px solid rgba(0,0,0,.05);}
.dcard:hover{transform:translateY(-5px);box-shadow:0 12px 36px rgba(0,0,0,.14);}
.dcard-img{position:relative;height:180px;overflow:hidden;background:#f0ebe4;}
.dcard-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s;display:block;}
.dcard:hover .dcard-img img{transform:scale(1.06);}
.img-fb{width:100%;height:100%;display:none;align-items:center;justify-content:center;font-size:4rem;}
.bdg{position:absolute;top:10px;right:10px;padding:3px 10px;border-radius:5px;font-size:11px;font-weight:800;letter-spacing:.3px;}
.bdg-g{background:var(--veg);color:#fff;}.bdg-r{background:var(--nonveg);color:#fff;}
.heart{position:absolute;top:10px;left:10px;width:30px;height:30px;background:rgba(255,255,255,.92);border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:transform .2s;box-shadow:0 2px 8px rgba(0,0,0,.12);}
.heart:hover{transform:scale(1.15);}
.dcard-body{padding:14px 16px 16px;}
.dcard-body h3{font-family:'Sora',sans-serif;font-size:15px;font-weight:700;margin-bottom:8px;}
.dcard-meta{display:flex;gap:14px;margin-bottom:10px;}
.dm{display:flex;align-items:center;gap:4px;font-size:12px;color:var(--muted);font-weight:600;}
.dm.star{color:var(--primary);}
.btn-view{width:100%;padding:8px 0;border:none;border-radius:8px;background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;}
.btn-view:hover{opacity:.88;transform:translateY(-1px);}

/* ═══ AI RECIPE GENERATOR ═══ */
.ai-sec{background:linear-gradient(135deg,#0F0C0A 0%,#1A1108 100%);border-top:2px solid rgba(232,93,4,.3);border-bottom:2px solid rgba(232,93,4,.3);position:relative;overflow:hidden;}
.ai-sec::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(232,93,4,.12) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(244,140,6,.08) 0%,transparent 50%);}
.ai-inner{max-width:760px;margin:0 auto;text-align:center;position:relative;z-index:1;}
.ai-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(232,93,4,.15);border:1px solid rgba(232,93,4,.4);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:700;color:var(--secondary);margin-bottom:16px;letter-spacing:.5px;}
.ai-inner h2{font-family:'Sora',sans-serif;font-size:2rem;font-weight:800;margin-bottom:10px;color:#fff;}
.ai-inner h2 span{background:linear-gradient(135deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.ai-inner>p{font-size:15px;color:rgba(255,255,255,.55);margin-bottom:28px;line-height:1.6;}
.ai-input-wrap{background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.12);border-radius:14px;padding:20px;margin-bottom:16px;backdrop-filter:blur(10px);}
.ai-input-row{display:flex;background:rgba(255,255,255,.08);border-radius:10px;border:1.5px solid rgba(255,255,255,.15);overflow:hidden;transition:border-color .2s;margin-bottom:14px;}
.ai-input-row:focus-within{border-color:var(--primary);}
.ai-input-row input{flex:1;padding:14px 18px;border:none;outline:none;font-family:'Nunito',sans-serif;font-size:15px;color:#fff;background:transparent;}
.ai-input-row input::placeholder{color:rgba(255,255,255,.3);}
.pills{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.pill{padding:7px 18px;border-radius:8px;border:1.5px solid rgba(255,255,255,.15);background:rgba(255,255,255,.05);color:rgba(255,255,255,.6);font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .18s;}
.pill.on,.pill:hover{background:var(--primary);color:#fff;border-color:var(--primary);}
.ai-row2{display:flex;justify-content:center;gap:12px;margin-bottom:18px;flex-wrap:wrap;}
.csel{padding:9px 18px;border-radius:8px;border:1.5px solid rgba(255,255,255,.15);background:rgba(255,255,255,.08);font-family:'Nunito',sans-serif;font-size:14px;font-weight:600;color:#fff;cursor:pointer;outline:none;transition:border-color .2s;}
.csel:focus{border-color:var(--primary);}
.csel option{background:#1a1108;color:#fff;}
.btn-gen{padding:15px 44px;border-radius:12px;border:none;background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;font-family:'Sora',sans-serif;font-size:16px;font-weight:700;cursor:pointer;box-shadow:0 6px 28px rgba(232,93,4,.45);transition:all .2s;width:100%;max-width:360px;display:flex;align-items:center;justify-content:center;gap:8px;margin:0 auto;}
.btn-gen:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 10px 36px rgba(232,93,4,.55);}
.btn-gen:disabled{opacity:.6;cursor:not-allowed;transform:none;}

/* AI result box */
.ai-result{margin-top:24px;background:rgba(255,255,255,.05);border:1.5px solid rgba(232,93,4,.3);border-radius:14px;padding:24px;text-align:left;display:none;animation:fadeUp .4s ease;}
.ai-result.show{display:block;}
.ai-result-title{font-family:'Sora',sans-serif;font-size:1.3rem;font-weight:800;color:#fff;margin-bottom:6px;}
.ai-result-meta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;}
.ai-result-meta span{background:rgba(232,93,4,.2);border:1px solid rgba(232,93,4,.3);color:var(--secondary);padding:4px 12px;border-radius:6px;font-size:12px;font-weight:700;}
.ai-result h4{font-family:'Sora',sans-serif;font-size:13px;font-weight:800;color:rgba(255,255,255,.7);margin-bottom:10px;text-transform:uppercase;letter-spacing:.8px;}
.ai-ing-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:7px;margin-bottom:20px;}
.ai-ing-item{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:7px;padding:7px 11px;font-size:13px;color:rgba(255,255,255,.8);font-weight:600;}
.ai-ing-item span{color:rgba(255,255,255,.4);font-size:11px;margin-left:6px;}
.ai-steps-list{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:18px;}
.ai-step{display:flex;gap:12px;align-items:flex-start;}
.ai-step-num{width:28px;height:28px;min-width:28px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;font-family:'Sora',sans-serif;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;margin-top:2px;}
.ai-step-text{font-size:14px;line-height:1.65;color:rgba(255,255,255,.75);padding-top:3px;}
.ai-tip{background:rgba(244,140,6,.1);border:1px solid rgba(244,140,6,.25);border-radius:8px;padding:12px 16px;font-size:13px;color:rgba(255,255,255,.65);line-height:1.6;}
.ai-tip b{color:var(--secondary);}
.ai-loading{text-align:center;padding:30px;display:none;}
.ai-loading.show{display:block;}
.ai-spinner{width:44px;height:44px;border:3px solid rgba(255,255,255,.1);border-top-color:var(--primary);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 14px;}
@keyframes spin{to{transform:rotate(360deg);}}
.ai-loading p{color:rgba(255,255,255,.5);font-size:14px;}
.ai-loading .ai-loading-steps{margin-top:8px;font-size:13px;color:rgba(255,255,255,.35);}

/* AI SUGGESTIONS */
.ai-suggestions{margin-top:18px;display:none;}
.ai-suggestions.show{display:block;}
.ai-sug-title{font-size:13px;font-weight:700;color:rgba(255,255,255,.45);margin-bottom:10px;text-align:left;}
.ai-sug-chips{display:flex;gap:8px;flex-wrap:wrap;}
.ai-sug-chip{padding:7px 14px;border-radius:8px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.7);font-size:13px;font-weight:600;cursor:pointer;transition:all .18s;}
.ai-sug-chip:hover{background:rgba(232,93,4,.2);border-color:var(--primary);color:#fff;}

/* ═══ WEEKLY MEAL PLANNER ═══ */
.planner-sec{background:linear-gradient(135deg,#FFF8F2 0%,#FFF3E8 100%);}
.planner-head{font-family:'Sora',sans-serif;font-size:1.6rem;font-weight:800;margin-bottom:6px;}
.planner-sub{color:var(--text2);font-size:15px;margin-bottom:24px;}
.planner-controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;align-items:center;}
.planner-sel{padding:9px 16px;border-radius:8px;border:1.5px solid var(--border);background:#fff;font-family:'Nunito',sans-serif;font-size:14px;font-weight:600;color:var(--text);cursor:pointer;outline:none;}
.planner-sel:focus{border-color:var(--primary);}
.btn-plan{padding:10px 22px;border-radius:8px;border:none;background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 3px 14px rgba(232,93,4,.32);transition:all .2s;display:flex;align-items:center;gap:6px;}
.btn-plan:hover:not(:disabled){transform:translateY(-1px);}
.btn-plan:disabled{opacity:.6;cursor:not-allowed;}
.planner-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:10px;margin-bottom:20px;}
.plan-day{background:#fff;border-radius:12px;padding:12px 10px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid rgba(0,0,0,.05);min-height:200px;}
.plan-day-label{font-family:'Sora',sans-serif;font-size:12px;font-weight:800;color:var(--primary);text-align:center;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.plan-meal{background:var(--bg);border-radius:8px;padding:8px 9px;margin-bottom:7px;border:1px solid var(--border);}
.plan-meal-type{font-size:10px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px;}
.plan-meal-name{font-size:12px;font-weight:700;color:var(--text);line-height:1.3;}
.plan-meal-cal{font-size:10px;color:var(--muted);margin-top:2px;}
.plan-meal.loading{opacity:.5;animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{opacity:.5;}50%{opacity:.8;}}
.plan-empty{text-align:center;color:var(--muted);font-size:12px;padding:20px 0;}
.plan-loading-overlay{text-align:center;padding:40px;display:none;}
.plan-loading-overlay.show{display:block;}
.plan-spinner{width:40px;height:40px;border:3px solid rgba(232,93,4,.15);border-top-color:var(--primary);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 12px;}
.plan-loading-overlay p{color:var(--text2);font-size:14px;font-weight:600;}
.plan-summary{background:#fff;border-radius:12px;padding:16px 20px;box-shadow:0 2px 12px rgba(0,0,0,.07);border:1px solid rgba(0,0,0,.05);display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px;}
.plan-stat{text-align:center;flex:1;min-width:80px;}
.plan-stat-val{font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:var(--primary);}
.plan-stat-lbl{font-size:11px;color:var(--muted);font-weight:600;margin-top:2px;}

/* SHOPPING */
.shop-h{font-family:'Sora',sans-serif;font-size:1.6rem;font-weight:800;margin-bottom:8px;}
.shop-sub{color:var(--text2);font-size:15px;margin-bottom:28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
.shop-count{font-size:14px;font-weight:700;color:var(--primary);background:rgba(232,93,4,.1);padding:4px 12px;border-radius:20px;}
.shop-card{max-width:480px;background:var(--white);border-radius:16px;padding:8px 0;box-shadow:0 2px 16px rgba(0,0,0,.09);margin-bottom:20px;border:1px solid rgba(0,0,0,.05);min-height:100px;transition:all 0.3s;}
.si{display:flex;align-items:center;gap:14px;padding:13px 22px;border-bottom:1px solid #F5EDE4;}
.si:last-child{border-bottom:none;}
.si input[type=checkbox]{width:17px;height:17px;accent-color:var(--primary);cursor:pointer;flex-shrink:0;}
.iname{flex:1;font-size:15px;font-weight:600;}
.iqty{font-size:13px;color:var(--muted);font-weight:600;background:#F5EDE4;padding:3px 10px;border-radius:6px;}
.si.done .iname{text-decoration:line-through;color:var(--muted);}
.btn-remove{background:transparent;border:none;color:#999;font-size:16px;cursor:pointer;padding:4px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.btn-remove:hover{color:#dc2626;background:#fee2e2;}
.shop-empty{text-align:center;padding:30px 20px;color:var(--muted);font-size:14px;font-weight:600;}
.shop-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:10px;}
.btn-f{padding:11px 22px;border-radius:8px;border:none;background:var(--primary);color:#fff;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 3px 12px rgba(232,93,4,.28);transition:all .2s;}
.btn-f:hover{background:#cf4f00;transform:translateY(-1px);}
.btn-o{padding:11px 22px;border-radius:8px;border:2px solid var(--primary);background:transparent;color:var(--primary);font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;}
.btn-o:hover{background:var(--primary);color:#fff;transform:translateY(-1px);}
.snote{font-size:12px;color:var(--muted);}

/* FEATURES */
.feat-h{font-family:'Sora',sans-serif;font-size:1.65rem;font-weight:800;text-align:center;margin-bottom:36px;}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:18px;}
.fc{background:var(--white);border-radius:14px;padding:28px 22px;box-shadow:0 2px 16px rgba(0,0,0,.08);border:1px solid rgba(0,0,0,.04);border-top:3px solid transparent;transition:border-color .22s,transform .22s,box-shadow .22s;}
.fc:hover{border-top-color:var(--primary);transform:translateY(-5px);box-shadow:0 14px 32px rgba(232,93,4,.1);}
.fi{width:48px;height:48px;background:linear-gradient(135deg,#FFF0E0,#FFE2C4);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:21px;margin-bottom:16px;}
.fc h3{font-family:'Sora',sans-serif;font-size:15px;font-weight:700;margin-bottom:7px;}
.fc p{font-size:13px;color:var(--text2);line-height:1.6;}

/* FOOTER */
footer{background:#1A1A1A;color:rgba(255,255,255,.65);padding:56px 5% 24px;}
.fg{display:grid;grid-template-columns:1.8fr 1fr 1fr;gap:48px;margin-bottom:40px;}
.fb .logo-name{color:var(--secondary);}
.fb p{font-size:13px;color:rgba(255,255,255,.4);line-height:1.7;margin-top:12px;max-width:280px;}
.fcol h4{color:#fff;font-size:14px;font-weight:700;margin-bottom:16px;}
.fcol ul{list-style:none;}
.fcol li{margin-bottom:10px;}
.fcol a{color:rgba(255,255,255,.45);text-decoration:none;font-size:13px;transition:color .2s;}
.fcol a:hover{color:var(--secondary);}
.socials{display:flex;gap:10px;margin-top:4px;}
.soc{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:15px;cursor:pointer;transition:all .2s;}
.soc:hover{background:var(--primary);transform:translateY(-2px);}
.fbot{border-top:1px solid rgba(255,255,255,.08);padding-top:20px;text-align:center;font-size:12px;color:rgba(255,255,255,.3);}
.fwelcome{background:linear-gradient(135deg,rgba(232,93,4,.18),rgba(244,140,6,.12));border:1px solid rgba(232,93,4,.3);border-radius:12px;padding:16px 24px;margin-bottom:28px;display:flex;align-items:center;gap:14px;}
.fwelcome-icon{width:44px;height:44px;background:linear-gradient(135deg,var(--primary),var(--secondary));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.fwelcome-text .fw-greeting{font-size:13px;color:rgba(255,255,255,.5);font-weight:600;margin-bottom:2px;}
.fwelcome-text .fw-name{font-family:'Sora',sans-serif;font-size:17px;font-weight:800;color:#fff;}
.fwelcome-text .fw-name span{color:var(--secondary);}
.fwelcome-text .fw-sub{font-size:12px;color:rgba(255,255,255,.4);margin-top:3px;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.58);z-index:999;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(4px);}
.modal-overlay.open{display:flex;}
.modal{background:#fff;border-radius:20px;width:100%;max-width:780px;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 32px 80px rgba(0,0,0,.3);animation:modalIn .3s ease;}
@keyframes modalIn{from{opacity:0;transform:scale(.94) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}
.modal-hero{position:relative;height:220px;flex-shrink:0;background:#f0ebe4;}
.modal-hero img{width:100%;height:100%;object-fit:cover;display:block;}
.modal-hero-fb{width:100%;height:100%;display:none;align-items:center;justify-content:center;font-size:5rem;}
.modal-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.62) 0%,rgba(0,0,0,.08) 60%);}
.modal-close{position:absolute;top:14px;right:14px;width:36px;height:36px;background:rgba(255,255,255,.92);border:none;border-radius:50%;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;transition:all .2s;box-shadow:0 2px 10px rgba(0,0,0,.2);z-index:2;}
.modal-close:hover{background:#fff;transform:scale(1.1);}
.modal-title-bar{position:absolute;bottom:16px;left:20px;right:60px;z-index:2;}
.modal-title-bar h2{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.5);}
.modal-title-bar .mbdg{display:inline-block;padding:3px 12px;border-radius:6px;font-size:11px;font-weight:800;margin-bottom:6px;}
.modal-body{overflow-y:auto;padding:24px 28px 32px;flex:1;}
.modal-body::-webkit-scrollbar{width:4px;}
.modal-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
.modal-stats{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:22px;}
.mstat{display:flex;align-items:center;gap:6px;background:#FFF5ED;border:1px solid #F0DDD0;border-radius:8px;padding:8px 14px;font-size:13px;font-weight:700;color:var(--text2);}
.mstat span{font-size:15px;}
.section-head{font-family:'Sora',sans-serif;font-size:15px;font-weight:800;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.section-head::after{content:'';flex:1;height:1px;background:var(--border);}
.ing-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:9px;margin-bottom:26px;}
.ing-chip{display:flex;align-items:center;gap:8px;background:#FAFAFA;border:1px solid var(--border);border-radius:9px;padding:9px 12px;font-size:13px;font-weight:600;}
.ing-chip .ico{font-size:17px;flex-shrink:0;}
.ing-chip .itext{flex:1;line-height:1.3;}
.ing-chip .qty{font-size:11px;color:var(--muted);background:#F0E8E0;padding:2px 8px;border-radius:5px;font-weight:700;white-space:nowrap;flex-shrink:0;}
.steps-list{list-style:none;display:flex;flex-direction:column;gap:14px;margin-bottom:16px;}
.step{display:flex;gap:14px;align-items:flex-start;}
.step-num{width:30px;height:30px;min-width:30px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;font-family:'Sora',sans-serif;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;margin-top:2px;}
.step-text{font-size:14px;line-height:1.7;color:var(--text2);padding-top:4px;}
