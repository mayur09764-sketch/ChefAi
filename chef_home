}

function exportPlan(){
  if(!currentPlan){alert('Please generate a meal plan first!');return;}
  let txt='🍽️ ChefAI Weekly Meal Plan\n'+'═'.repeat(40)+'\n\n';
  currentPlan.days.forEach(d=>{
    txt+=`📅 ${d.day}\n`;
    txt+=`  🌅 Breakfast: ${d.breakfast.name} (${d.breakfast.calories})\n`;
    txt+=`  ☀️  Lunch:     ${d.lunch.name} (${d.lunch.calories})\n`;
    txt+=`  🌙 Dinner:    ${d.dinner.name} (${d.dinner.calories})\n\n`;
  });
  txt+=`Target: ~${currentPlan.totalCalories} kcal/day\nGenerated by ChefAI × Gemini 1.5 Flash`;
  const blob=new Blob([txt],{type:'text/plain'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='ChefAI_MealPlan.txt';
  a.click();
}

// ═══ DISH CARDS ═══
function card(d,isV){
  const badge=isV?`<span class="bdg bdg-g">Veg</span>`:`<span class="bdg bdg-r">Non-Veg</span>`;
  const safeD=JSON.stringify(d).replace(/'/g,"&#39;").replace(/"/g,"&quot;");
  return `<div class="dcard" onclick="openModal(JSON.parse(this.dataset.d),${isV})" data-d="${safeD}">
    <div class="dcard-img">
      <img src="${d.img}" alt="${d.n}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
      <div class="img-fb" style="background:${d.bg}">${d.em}</div>
      ${badge}
      <button class="heart" onclick="event.stopPropagation();this.textContent=this.textContent==='♡'?'♥':'♡';this.style.color=this.textContent==='♥'?'#E85D04':''">♡</button>
    </div>
    <div class="dcard-body">
      <h3>${d.n}</h3>
      <div class="dcard-meta">
        <span class="dm">⏱ ${d.t}</span>
        <span class="dm">⚡ ${d.c}</span>
        <span class="dm star">★ ${d.r}</span>
      </div>
      <button class="btn-view" onclick="event.stopPropagation();openModal(JSON.parse(this.closest('.dcard').dataset.d),${isV})">📖 View Recipe & Ingredients</button>
    </div>
  </div>`;
}
document.getElementById('vr').innerHTML=veg.map(d=>card(d,true)).join('');
document.getElementById('nr').innerHTML=nv.map(d=>card(d,false)).join('');

// ═══ MODAL ═══
function openModal(d,isV){
  const img=document.getElementById('mImg');
  const fb=document.getElementById('mFb');
  img.src=d.img; img.style.display='block'; fb.style.display='none';
  img.onerror=function(){this.style.display='none';fb.style.display='flex';fb.style.background=d.bg;fb.textContent=d.em;};
  const bdg=document.getElementById('mBdg');
  bdg.textContent=isV?'🥗 Vegetarian':'🍗 Non-Vegetarian';
  bdg.style.background=isV?'#16A34A':'#DC2626';
  bdg.style.color='#fff';
  document.getElementById('mTitle').textContent=d.n;
  document.getElementById('mStats').innerHTML=
    `<div class="mstat"><span>⏱</span> ${d.t}</div><div class="mstat"><span>⚡</span> ${d.c}</div><div class="mstat"><span>★</span> ${d.r} Rating</div><div class="mstat"><span>🍽️</span> Serves 4</div>`;
  document.getElementById('mIngredients').innerHTML=
    d.ing.map(i=>`<div class="ing-chip"><span class="ico">${i.ico}</span><span class="itext">${i.name}</span><span class="qty">${i.qty}</span></div>`).join('');
  document.getElementById('mSteps').innerHTML=
    d.steps.map((s,i)=>`<li class="step"><div class="step-num">${i+1}</div><div class="step-text">${s}</div></li>`).join('');
  document.getElementById('mTip').innerHTML=d.tip;
  
  if (!document.getElementById('mShopBtn')) {
    const btn = document.createElement('button');
    btn.id = 'mShopBtn';
    btn.className = 'btn-gen';
    btn.style.marginTop = '24px';
    btn.style.width = '100%';
    btn.style.maxWidth = '100%';
    btn.textContent = '🛒 Add to Shopping List';
    btn.onclick = addToShoppingM;
    document.querySelector('.modal-body').appendChild(btn);
  }
  
  currentModalDish = d;
  document.getElementById('recipeModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(e){if(e.target===document.getElementById('recipeModal')) closeModalDirect();}
function closeModalDirect(){document.getElementById('recipeModal').classList.remove('open');document.body.style.overflow='';}
document.addEventListener('keydown',e=>{if(e.key==='Escape') closeModalDirect();});
function tc(id){document.getElementById(id).classList.toggle('done');}

// ═══ SHOPPING LIST LOGIC ═══
let shoppingList = [];
let currentModalDish = null;

function renderShoppingList() {
  const container = document.getElementById('shopCard');
  const countEl = document.getElementById('shopCount');
  
  if (shoppingList.length === 0) {
    container.innerHTML = `<div class="shop-empty">Your shopping list is empty!<br><br><span style="font-size:12px;font-weight:400;">Browse dishes, generate recipes, or plan meals to add ingredients here.</span></div>`;
    countEl.textContent = '0 items';
    return;
  }
  
  let html = '';
  let pendingCount = 0;
  
  shoppingList.forEach((item, index) => {
    const isDone = item.done ? 'done' : '';
    const checked = item.done ? 'checked' : '';
    if (!item.done) pendingCount++;
    
    html += `<div class="si ${isDone}">
      <input type="checkbox" ${checked} onchange="toggleShopItem(${index})">
      <span class="iname">${item.name}</span>
      <span class="iqty">${item.qty}</span>
      <button class="btn-remove" onclick="removeShopItem(${index})">✕</button>
    </div>`;
  });
  
  container.innerHTML = html;
  countEl.textContent = `${pendingCount} of ${shoppingList.length} items remaining`;
}

function addIngredientsToList(ingredientsArray, sourceName) {
  let addedCount = 0;
  ingredientsArray.forEach(ing => {
    // Avoid exact duplicates (name + qty combination)
    const exists = shoppingList.find(i => i.name.toLowerCase() === ing.name.toLowerCase() && i.qty === ing.qty);
    if (!exists) {
      shoppingList.push({ name: ing.name, qty: ing.qty, done: false });
      addedCount++;
    }
  });
  
  renderShoppingList();
  
  const note = document.getElementById('shopNote');
  if (addedCount > 0) {
    note.textContent = `✅ Successfully added ${addedCount} new ingredients from ${sourceName}!`;
    note.style.color = 'var(--veg)';
    setTimeout(() => { note.textContent = "Shopping list tracks all your added ingredients."; note.style.color = "var(--muted)"; }, 4000);
  } else {
    note.textContent = `ℹ️ Ingredients from ${sourceName} are already in your list.`;
    setTimeout(() => { note.textContent = "Shopping list tracks all your added ingredients."; note.style.color = "var(--muted)"; }, 4000);
  }
}

function toggleShopItem(index) {
  shoppingList[index].done = !shoppingList[index].done;
  renderShoppingList();
}

function removeShopItem(index) {
  shoppingList.splice(index, 1);
  renderShoppingList();
}

function clearShoppingList() {
  if (shoppingList.length === 0) return;
  if (confirm("Are you sure you want to clear your entire shopping list?")) {
    shoppingList = [];
    renderShoppingList();
  }
}

function copyShoppingList() {
  const pending = shoppingList.filter(i => !i.done);
  if (pending.length === 0) {
    alert("No remaining items to copy!");
    return;
  }
  
  const txt = "🛒 ChefAI Shopping List\n" + "═".repeat(30) + "\n" + pending.map(i => `[ ] ${i.name} - ${i.qty}`).join("\n");
  navigator.clipboard.writeText(txt).then(() => {
    const btn = document.querySelector('.btn-f');
    const oldText = btn.innerHTML;
    btn.innerHTML = '✅ Copied!';
    setTimeout(() => btn.innerHTML = oldText, 2000);
  });
}

function addToShoppingM() {
  if (currentModalDish) {
    addIngredientsToList(currentModalDish.ing, `"${currentModalDish.n}"`);
    closeModalDirect();
    document.getElementById('shopping').scrollIntoView({behavior:'smooth'});
  }
}

function addToShoppingAI() {
  if (currentAIRecipe && currentAIRecipe.ingredients) {
    addIngredientsToList(currentAIRecipe.ingredients, `AI Recipe "${currentAIRecipe.name}"`);
    document.getElementById('shopping').scrollIntoView({behavior:'smooth'});
  }
}

function addToShoppingPlan() {
  if (currentPlan && currentPlan.weeklyIngredients) {
    addIngredientsToList(currentPlan.weeklyIngredients, "Weekly Meal Plan");
    document.getElementById('shopping').scrollIntoView({behavior:'smooth'});
  }
}

// Init empty shopping list UI
renderShoppingList();
</script>
