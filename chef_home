const veg=[
  {n:"Dal Makhani",t:"30 mins",c:"350 kcal",r:"4.8",em:"🍲",img:"https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=500&q=80",bg:"linear-gradient(135deg,#FFD6A0,#FFA040)",ing:[{ico:"🫘",name:"Whole Black Urad Dal",qty:"1 cup"},{ico:"🫘",name:"Rajma (Kidney Beans)",qty:"¼ cup"},{ico:"🧈",name:"Butter",qty:"3 tbsp"},{ico:"🫙",name:"Fresh Cream",qty:"4 tbsp"},{ico:"🍅",name:"Tomato Puree",qty:"½ cup"},{ico:"🧅",name:"Onion",qty:"1 large"},{ico:"🧄",name:"Garlic",qty:"6 cloves"},{ico:"🌿",name:"Ginger",qty:"1 inch"},{ico:"🌶️",name:"Red Chilli Powder",qty:"1 tsp"},{ico:"🫙",name:"Garam Masala",qty:"1 tsp"},{ico:"🫙",name:"Coriander Powder",qty:"1 tsp"},{ico:"🧂",name:"Salt",qty:"to taste"}],steps:["<strong>Soak overnight:</strong> Soak urad dal and rajma in plenty of water overnight. Drain before cooking.","<strong>Pressure cook:</strong> Add soaked dal, rajma, 3 cups water, and salt. Cook for 6–8 whistles until completely soft. Lightly mash with a ladle.","<strong>Make the masala:</strong> Heat butter in a heavy pan. Sauté onions until deep golden brown (~12 mins). Add garlic and ginger, cook 2 mins.","<strong>Add tomatoes & spices:</strong> Stir in tomato puree, red chilli powder, and coriander powder. Cook on medium heat until oil separates (~8 mins).","<strong>Combine & simmer:</strong> Add the cooked dal to the masala. Simmer on very low heat for 20–25 mins, stirring occasionally.","<strong>Finish:</strong> Stir in fresh cream and garam masala. Simmer 5 more mins. Top with a knob of butter and serve hot."],tip:"💡 <b>Chef's Tip:</b> The longer you simmer Dal Makhani on a low flame, the richer the flavour. Restaurant-style dal is often slow-cooked for 4–6 hours!"},
