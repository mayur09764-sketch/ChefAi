function renderMealPlan(plan){
  const grid=document.getElementById('plannerGrid');
  grid.innerHTML=plan.days.map(d=>`
    <div class="plan-day">
      <div class="plan-day-label">${d.day}</div>
      <div class="plan-meal">
        <div class="plan-meal-type">🌅 Breakfast</div>
        <div class="plan-meal-name">${d.breakfast.name}</div>
        <div class="plan-meal-cal">${d.breakfast.calories}</div>
      </div>
      <div class="plan-meal">
        <div class="plan-meal-type">☀️ Lunch</div>
        <div class="plan-meal-name">${d.lunch.name}</div>
        <div class="plan-meal-cal">${d.lunch.calories}</div>
      </div>
      <div class="plan-meal">
        <div class="plan-meal-type">🌙 Dinner</div>
        <div class="plan-meal-name">${d.dinner.name}</div>
